# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017
DB_NAME=zettl

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_real_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Uploads ────────────────────────────────────────────────────────────────
# Local filesystem (dev). Switch to cloudinary in Phase 6.
UPLOAD_DIR=/uploads
MAX_UPLOAD_SIZE_MB=5

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# ─── Cloudinary (Phase 6 — leave blank for local dev) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Frontend (Vite env vars must start with VITE_) ─────────────────────────
VITE_API_BASE_URL=http://localhost/api
